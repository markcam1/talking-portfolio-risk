# Dependencies
**/node_modules/

# Build output
**/dist/

# Environment files — never commit secrets
**/.env
# Allow the example template
!.env.example

# Runtime data (compliance bundles are permanent but local-only)
**/data/
**/logs/
**/.dev/

# SQLite databases
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite-journal

# Prisma generated client (regenerated by npm run db:generate)
backend/node_modules/.prisma/

# OS / editor
.DS_Store
.vscode/settings.json
*.swp

# Internal planning docs — not for public repo
PLAN.md
talking-portfolio-spec.md
